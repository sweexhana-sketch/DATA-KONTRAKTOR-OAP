{
    "version": 2,
    "public": true,
    "rewrites": [
        {
            "source": "/api/auth/(.*)",
            "destination": "/api/index.mjs"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index.mjs"
        },
        {
            "source": "/integrations/(.*)",
            "destination": "/api/index.mjs"
        },
        {
            "source": "/assets/(.*)",
            "destination": "/apps/web/build/client/assets/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index.mjs"
        }
    ]
}